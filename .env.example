# GymFlow deployment environment example.
# Copy to .env on a server or configure these values in the hosting platform.

# Frontend build/runtime
VITE_GYMFLOW_API_BASE_URL=https://api.your-domain.com
VITE_GYMFLOW_API_MODE=backend

# Backend
PORT=4100
GYMFLOW_REPOSITORY=postgres

# PostgreSQL
GYMFLOW_CENTRAL_DATABASE_URL=postgres://gymflow:gymflow_dev_password@localhost:5432/gymflow_central
GYMFLOW_POSTGRES_ADMIN_URL=postgres://gymflow_admin:gymflow_admin_password@localhost:5432/postgres
GYMFLOW_TENANT_DATABASE_URL_TEMPLATE=postgres://gymflow:gymflow_dev_password@localhost:5432/{database}

# Optional compatibility aliases for older deployment scripts
# DATABASE_URL=postgres://gymflow:gymflow_dev_password@localhost:5432/gymflow_central
# POSTGRES_ADMIN_DATABASE_URL=postgres://gymflow_admin:gymflow_admin_password@localhost:5432/postgres
# TENANT_DATABASE_URL_TEMPLATE=postgres://gymflow:gymflow_dev_password@localhost:5432/{database}
